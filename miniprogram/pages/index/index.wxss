.page {
  min-height: 100vh;
  padding: 24rpx 36rpx calc(48rpx + env(safe-area-inset-bottom));
  position: relative;
  overflow: hidden;
  background: linear-gradient(180deg, #f4fbff 0%, #edf7ff 45%, #e8f6f2 100%);
  box-sizing: border-box;
}

.decor {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
}
.sun {
  width: 240rpx;
  height: 240rpx;
  right: -40rpx;
  top: -20rpx;
  background: rgba(255, 199, 74, 0.55);
  filter: blur(2rpx);
}
.mint {
  width: 300rpx;
  height: 300rpx;
  left: -100rpx;
  bottom: 120rpx;
  background: rgba(97, 209, 176, 0.28);
}
.cloud {
  position: absolute;
  width: 140rpx;
  height: 70rpx;
  left: 40rpx;
  top: 120rpx;
  background: rgba(255, 255, 255, 0.88);
  border-radius: 999rpx;
  z-index: 0;
}
.cloud::before,
.cloud::after {
  content: "";
  position: absolute;
  background: inherit;
  border-radius: 50%;
}
.cloud::before {
  width: 64rpx;
  height: 64rpx;
  left: 18rpx;
  top: -28rpx;
}
.cloud::after {
  width: 80rpx;
  height: 80rpx;
  right: 14rpx;
  top: -34rpx;
}

.top,
.stage,
.section,
.settings-entry,
.alert-card {
  position: relative;
  z-index: 1;
}

.top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.title {
  font-size: 52rpx;
  font-weight: 800;
  color: #384a50;
  line-height: 1.15;
}
.accent { color: #f0a820; }
.tagline {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #7a9096;
  font-weight: 600;
}
.gear {
  width: 80rpx;
  height: 80rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid #b8dbe6;
  box-shadow: 0 12rpx 28rpx rgba(120, 175, 200, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.stage {
  background: #fff;
  border: 2rpx solid #b8dbe6;
  border-radius: 48rpx;
  box-shadow: 0 16rpx 40rpx rgba(120, 175, 200, 0.16);
  padding: 36rpx 28rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.stage.alerting {
  box-shadow: 0 18rpx 44rpx rgba(255, 139, 125, 0.25);
}

.ring-wrap {
  width: 460rpx;
  height: 460rpx;
  position: relative;
  margin-bottom: 8rpx;
}
.ring-bg,
.ring-fill {
  position: absolute;
  inset: 0;
  border-radius: 50%;
}
.ring-bg { background: #e5f3f8; }
.ring-fill {
  mask: radial-gradient(transparent 58%, #000 59%);
  -webkit-mask: radial-gradient(transparent 58%, #000 59%);
}
.ring-center {
  position: absolute;
  inset: 56rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 0 0 2rpx rgba(184, 219, 230, 0.35);
}
.display {
  font-size: 56rpx;
  font-weight: 700;
  font-family: "DIN Alternate", "Helvetica Neue", monospace;
  letter-spacing: 2rpx;
  color: #384a50;
}
.display.urgent { color: #ff8b7d; }
.display.done { color: #f0a820; }

.status {
  min-height: 40rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #7a9096;
  margin: 8rpx 0 20rpx;
}
.status.ok { color: #61d1b0; }
.status.hot { color: #ff8b7d; }

.controls {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
  width: 100%;
}
.controls .btn {
  margin: 0;
  padding: 0 40rpx;
}

.section { margin-top: 28rpx; }
.section-title {
  font-size: 26rpx;
  color: #7a9096;
  font-weight: 800;
  margin-bottom: 16rpx;
}
.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}
.chip {
  min-height: 72rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #fff;
  border: 2rpx solid #b8dbe6;
  color: #384a50;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 20rpx rgba(120, 175, 200, 0.1);
}
.chip.active {
  background: #ffc74a;
  border-color: transparent;
  color: #4a3808;
}

.settings-entry {
  margin-top: 24rpx;
  padding: 26rpx 28rpx;
  background: #fff8e8;
  border: 2rpx solid #f3d89a;
  border-radius: 36rpx;
  box-shadow: 0 12rpx 28rpx rgba(120, 175, 200, 0.12);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.settings-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #f0a820;
}
.settings-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #7a9096;
  font-weight: 600;
}
.chevron {
  font-size: 44rpx;
  color: #f0a820;
  font-weight: 700;
}

.alert-card {
  margin-top: 24rpx;
  padding: 24rpx 28rpx;
  background: #fff1ee;
  border: 2rpx solid #ffc4bc;
  border-radius: 36rpx;
  box-shadow: 0 12rpx 28rpx rgba(255, 139, 125, 0.12);
}
.alert-row {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  font-size: 26rpx;
  font-weight: 800;
  margin-bottom: 16rpx;
}
.alert-row .l { color: #ff8b7d; flex: 1; }
.alert-row .r { color: #7a9096; font-weight: 700; }
.bar {
  height: 14rpx;
  border-radius: 99rpx;
  background: rgba(255, 255, 255, 0.85);
  overflow: hidden;
}
.bar-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #ffc74a, #ff8b7d);
  transition: width 0.1s linear;
}
.alert-hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #7a9096;
  font-weight: 600;
}

.toast {
  position: fixed;
  left: 50%;
  bottom: calc(64rpx + env(safe-area-inset-bottom));
  transform: translateX(-50%);
  background: rgba(56, 74, 80, 0.92);
  color: #fff;
  padding: 18rpx 32rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 700;
  z-index: 99;
  white-space: nowrap;
}
