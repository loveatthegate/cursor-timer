.page {
  min-height: 100vh;
  padding: 24rpx 32rpx calc(48rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #f4fbff 0%, #edf7ff 50%, #e8f6f2 100%);
  box-sizing: border-box;
}

.card {
  background: #fff;
  border: 2rpx solid #b8dbe6;
  border-radius: 36rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 28rpx rgba(120, 175, 200, 0.1);
}
.card-title {
  font-size: 28rpx;
  font-weight: 800;
  margin-bottom: 20rpx;
  color: #384a50;
}

.hms {
  display: flex;
  gap: 16rpx;
}
.unit {
  flex: 1;
  text-align: center;
}
.unit-label {
  font-size: 22rpx;
  color: #7a9096;
  font-weight: 700;
  margin-bottom: 10rpx;
}
.stepper {
  background: #e8f8f3;
  border: 2rpx solid #b8dbe6;
  border-radius: 28rpx;
  padding: 10rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  align-items: center;
}
.step-btn {
  width: 100%;
  height: 64rpx;
  border-radius: 20rpx;
  background: #fff;
  border: 2rpx solid #b8dbe6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #384a50;
}
.step-val {
  font-size: 40rpx;
  font-weight: 800;
  font-family: "DIN Alternate", monospace;
  color: #384a50;
  padding: 8rpx 0;
}

.seg {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 8rpx;
}
.seg-item {
  min-height: 68rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #fff;
  border: 2rpx solid #b8dbe6;
  color: #384a50;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
}
.seg-item.active {
  background: #ffc74a;
  border-color: transparent;
  color: #4a3808;
}

.field {
  margin-top: 22rpx;
}
.field-label {
  font-size: 24rpx;
  color: #7a9096;
  font-weight: 700;
  margin-bottom: 8rpx;
}
.field-value {
  text-align: right;
  font-size: 24rpx;
  color: #7a9096;
  font-weight: 700;
  margin-top: 4rpx;
}
.field-value.sun { color: #f0a820; }

.picker {
  background: #eef8fc;
  border: 2rpx solid #b8dbe6;
  border-radius: 24rpx;
  padding: 22rpx 24rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #384a50;
}

.textarea {
  width: 100%;
  min-height: 140rpx;
  background: #eef8fc;
  border: 2rpx solid #b8dbe6;
  border-radius: 24rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #384a50;
  box-sizing: border-box;
}

.check {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 24rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #384a50;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 8rpx;
}
.actions .btn {
  width: 100%;
  margin: 0;
}

.hint {
  margin-top: 20rpx;
  font-size: 22rpx;
  color: #7a9096;
  line-height: 1.5;
  font-weight: 600;
}
